{
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "incremental": true,
    "jsx": "react",
    "lib": ["ESNext", "DOM"],
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "+infra": ["./infra/index"],
      "+infra/*": ["./infra/*"],
      "+app": ["./app/index"],
      "+app/*": ["./app/*"],
      "+languages": ["./modules/languages.ts"],
      "+notifier": ["./modules/notifier/index"],
      "+notifier/*": ["./modules/notifier/*"]
    },
    "types": ["bun"]
  },
  "exclude": ["bgord-scripts"]
}
